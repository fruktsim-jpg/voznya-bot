# ============================================================================
#  Пример файла настроек для бота "Возня".
#  Скопируй этот файл в .env и заполни своими значениями:
#      cp .env.example .env
#  Файл .env НИКОМУ не показывай — в нём секретный токен бота.
# ============================================================================

# --- Telegram ---------------------------------------------------------------

# Токен бота, который выдаёт @BotFather при создании бота.
BOT_TOKEN=8785112116:AAEmgcTMnAFCXjSEto7dit8mxWIqJLaCiiM

# Username бота без @. Нужен для Mini App deep links из групп:
# https://t.me/<BOT_USERNAME>/<MINI_APP_SHORT_NAME>?startapp=...
BOT_USERNAME=voznyanlbot

# Short name/path Mini App из @BotFather. Это сегмент <app> в ссылке:
# https://t.me/<bot>/<app>
# Если пусто — групповые кнопки остаются обычными URL сайта.
MINI_APP_SHORT_NAME=voznya

# ID чата "Возня", в котором работает бот (обычно отрицательное число для групп).
# Как узнать: добавь бота в чат и посмотри логи, либо используй @getidsbot.
CHAT_ID=-1003278808005

# ID администраторов бота через запятую (тех, кому доступны админ-команды).
# Свой ID можно узнать у @userinfobot.
ADMIN_IDS=8354006262

# --- База данных ------------------------------------------------------------
# Эти значения используются и ботом, и контейнером PostgreSQL в docker-compose.
POSTGRES_USER=voznya
POSTGRES_PASSWORD=h1nt337
POSTGRES_DB=voznya

# Строка подключения к БД.
# Для docker-compose host = "db" (имя сервиса). Менять обычно не нужно.
DATABASE_URL=postgresql+asyncpg://voznya:h1nt337@db:5432/voznya

# --- Прочее -----------------------------------------------------------------

# Часовой пояс для игровых суток и сбросов (по умолчанию Амстердам).
TIMEZONE=Europe/Amsterdam

# Час сброса номинаций (Пидор/Пара дня). 0 = смена в 00:00 (полночь).

# Сам выбор «ленивый»: новый победитель определяется первым вызовом команды
# после полуночи.
NOMINATION_RESET_HOUR=0


# Уровень логирования: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

