# ============================================================================
#  Пример файла настроек для бота "Возня".
#  Скопируй этот файл в .env и заполни своими значениями:
#      cp .env.example .env
#  Файл .env НИКОМУ не показывай — в нём секретный токен бота.
# ============================================================================

# --- Telegram ---------------------------------------------------------------

# Токен бота, который выдаёт @BotFather при создании бота.
BOT_TOKEN=123456789:AA-ваш-токен-от-BotFather

# ID чата "Возня", в котором работает бот (обычно отрицательное число для групп).
# Как узнать: добавь бота в чат и посмотри логи, либо используй @getidsbot.
CHAT_ID=-1001234567890

# ID администраторов бота через запятую (тех, кому доступны админ-команды).
# Свой ID можно узнать у @userinfobot.
ADMIN_IDS=111111111,222222222

# --- База данных ------------------------------------------------------------
# Эти значения используются и ботом, и контейнером PostgreSQL в docker-compose.
POSTGRES_USER=voznya
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=voznya

# Строка подключения к БД.
# Для docker-compose host = "db" (имя сервиса). Менять обычно не нужно.
DATABASE_URL=postgresql+asyncpg://voznya:change-me-please@db:5432/voznya

# --- Прочее -----------------------------------------------------------------

# Часовой пояс для игровых суток и сбросов (по умолчанию Амстердам).
TIMEZONE=Europe/Amsterdam

# Час сброса номинаций (Пидор/Пара дня). 0 = смена в 00:00 (полночь).

# Сам выбор «ленивый»: новый победитель определяется первым вызовом команды
# после полуночи.
NOMINATION_RESET_HOUR=0


# Уровень логирования: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Реальная выдача Telegram Gifts через Bot API (sendGift). По умолчанию false:
# покупка за ешки работает и фиксируется, но подарок остаётся в статусе pending
# (реальные Stars не тратятся), пока не подключён доступ и баланс Stars у бота.
# Включать только когда бот реально может отправлять подарки. См.
# TELEGRAM_GIFTS_AUDIT.md.
GIFTS_DELIVERY_ENABLED=false


# --- Combot (только для разового импорта истории) ---------------------------
# Нужны ТОЛЬКО скрипту scripts/import_combot_history.py. Сам бот их не читает.
# Ключ — секрет: реальное значение в .env, в git НЕ коммитить.
COMBOT_API_KEY=
# chat_id для Combot. Если пусто — берётся CHAT_ID выше.
COMBOT_CHAT_ID=
# Начало периода выгрузки в Unix-миллисекундах (по умолчанию 2020-01-01).
COMBOT_FROM_MS=1577836800000


